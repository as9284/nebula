# Monorepo root — copy to .env.local (web reads from apps/web/.env.local or repo root)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required in production for auth redirects, canonical URLs, sitemap, and social previews (Open Graph / Twitter).
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
