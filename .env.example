# Supabase (required for cloud sync and magic-link auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public app URL — required in production so magic links do not fall back to localhost
# Example: https://nebula.vercel.app or your custom domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
