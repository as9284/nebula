{
  "name": "nebula-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1"
  },
  "scripts": {
    "dev": "npm run dev -w @nebula/web",
    "dev:web": "npm run dev -w @nebula/web",
    "build": "npm run build -w @nebula/core && npm run build -w @nebula/web",
    "build:web": "npm run build -w @nebula/web",
    "build:core": "npm run build -w @nebula/core",
    "lint": "npm run lint -w @nebula/web"
  }
}
