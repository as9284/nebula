{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@nebula/core": ["../../packages/core/src/index.ts"],
      "@nebula/core/*": ["../../packages/core/src/*"],
      "@nebula/theme": ["../../packages/theme/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
